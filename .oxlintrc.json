{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "style": "off"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": "error"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "coverage",
    "test-results",
    "playwright-report",
    "e2e/.cache"
  ]
}
